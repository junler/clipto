{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clipto",
  "version": "0.1.0",
  "identifier": "com.junler.clipto",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "popup",
        "url": "index.html",
        "title": "Clipto",
        "width": 280,
        "height": 380,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": true,
        "transparent": true
      },
      {
        "label": "main",
        "url": "index.html#/main",
        "title": "Clipto — 全部记录",
        "width": 960,
        "height": 600,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
